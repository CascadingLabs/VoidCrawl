# Copy to `.env` in this directory and edit.
# `docker compose -f docker/docker-compose.headful.yml` picks this up automatically.

# Pull a published image instead of building locally.
# Leave unset to build from the local Dockerfile.
#VOIDCRAWL_IMAGE=ghcr.io/cascadinglabs/voidcrawl:headful-latest

# Display resolution for headful Chrome / VNC.
VNC_WIDTH=1920
VNC_HEIGHT=1080

# Which GPU profile to use. Run-headful.sh auto-detects; set this for
# compose-native invocations (`docker compose up`) to skip the wrapper.
#COMPOSE_PROFILES=amd

# Optional: rewrite /etc/resolv.conf at container start when Docker inherits an
# unreachable host stub resolver. Comma or whitespace separated.
#VOIDCRAWL_DNS_SERVERS=1.1.1.1,8.8.8.8

# Chrome profiles. Default /tmp = ephemeral (wiped when the container stops).
# Set to /profiles to PERSIST logins, cookies, and Cloudflare clearance in the
# `voidcrawl-*-profiles` Docker volume — log in / clear a wall once, reuse it.
# Each Chrome gets its own subdir (chrome-profile-1, chrome-profile-2).
# Reset with `docker compose -f docker/docker-compose.headful.yml down -v`.
#CHROME_PROFILES_DIR=/profiles
